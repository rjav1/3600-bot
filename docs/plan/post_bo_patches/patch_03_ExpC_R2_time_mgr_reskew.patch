+# --- v0.4 Exp C + R2: phase multipliers + cumulative ceiling -----------
+
+
+def test_multiplier_by_phase():
+    """v0.4 Exp C: phase-driven multipliers replace the v0.2 easy/normal
+    labels. Opening (turns_left > 30) → 0.3×, mid (10 < turns_left ≤ 30)
+    → 1.3×, endgame (turns_left ≤ 10) → 2.5×. Budget should track the
+    multiplier proportionally at base = usable / turns_left.
+    """
+    from RattleBot.time_mgr import (
+        PHASE_MULT_OPENING,
+        PHASE_MULT_MID,
+        PHASE_MULT_ENDGAME,
+        SEARCH_OVERHEAD_PAD_S,
+    )
+
+    assert PHASE_MULT_OPENING == 0.3
+    assert PHASE_MULT_MID == 1.3
+    assert PHASE_MULT_ENDGAME == 2.5
+
+    # Opening: turns_left=35, time_left=180 → base=(179.5)/35≈5.13 s
+    # → 0.3× = 1.54 s, under 6 s ceiling, minus 0.3 s pad ≈ 1.24 s.
+    b = _board()
+    b.player_worker.turns_left = 35
+    tm = TimeManager(per_turn_ceiling_s=6.0)
+    budget_open = tm.start_turn(b, lambda: 180.0)
+    expected_open = (179.5 / 35) * PHASE_MULT_OPENING - SEARCH_OVERHEAD_PAD_S
+    assert abs(budget_open - expected_open) < 1e-6, (
+        f"opening: expected {expected_open:.3f}, got {budget_open:.3f}"
+    )
+
+    # Mid: turns_left=20 → base=(179.5)/20≈8.98 s → 1.3× = 11.67 s,
+    # clamped by 6 s ceiling, minus 0.3 s pad = 5.7 s.
+    b = _board()
+    b.player_worker.turns_left = 20
+    tm = TimeManager(per_turn_ceiling_s=6.0)
+    budget_mid = tm.start_turn(b, lambda: 180.0)
+    # The 6 s ceiling is the active upper bound here.
+    assert abs(budget_mid - (6.0 - SEARCH_OVERHEAD_PAD_S)) < 1e-6, (
+        f"mid: expected ~5.7s, got {budget_mid:.3f}"
+    )
+
+    # Endgame: turns_left=8 → base=(179.5)/8≈22.44 s → 2.5× = 56.1 s,
+    # clamped by endgame ceiling 20 s, minus 0.3 s pad = 19.7 s.
+    b = _board()
+    b.player_worker.turns_left = 8
+    tm = TimeManager(per_turn_ceiling_s=6.0)
+    budget_end = tm.start_turn(b, lambda: 180.0)
+    assert abs(budget_end - (20.0 - SEARCH_OVERHEAD_PAD_S)) < 1e-6, (
+        f"endgame: expected ~19.7s, got {budget_end:.3f}"
+    )
+
+
+def test_220s_cumulative_cap():
+    """R2 (LOSS_FORENSICS_APR17 §4.R2): once cumulative_used reaches
+    HARD_CUM_CEILING_S (220 s), start_turn returns the floor budget
+    (_MIN_BUDGET_S) so search aborts and we ship the fallback move.
+    The clamp also applies progressively below the ceiling: the
+    remaining cumulative budget is an upper bound on every turn.
+    """
+    from RattleBot.time_mgr import HARD_CUM_CEILING_S
+
+    assert HARD_CUM_CEILING_S == 220.0
+
+    # At the ceiling: start_turn must return _MIN_BUDGET_S (0.05).
+    b = _board()
+    b.player_worker.turns_left = 8  # endgame, would otherwise give big budget
+    tm = TimeManager(per_turn_ceiling_s=6.0)
+    tm.cumulative_used = HARD_CUM_CEILING_S
+    budget = tm.start_turn(b, lambda: 40.0)
+    assert budget <= 0.05 + 1e-9, (
+        f"R2 cumulative guard: expected _MIN_BUDGET_S, got {budget:.6f}"
+    )
+
+    # Just below the ceiling: budget must not exceed (ceiling - used).
+    b = _board()
+    b.player_worker.turns_left = 8
+    tm = TimeManager(per_turn_ceiling_s=6.0)
+    tm.cumulative_used = HARD_CUM_CEILING_S - 2.0  # 2 s left
+    budget = tm.start_turn(b, lambda: 40.0)
+    assert budget <= 2.0 + 1e-6, (
+        f"R2 progressive clamp: expected <= 2.0s, got {budget:.3f}"
+    )
+
+
 if __name__ == "__main__":
